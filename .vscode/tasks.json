{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C++: Build active file (MSVC C++20)",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/d",
                "/c",
                "\"${workspaceFolder}\\scripts\\build_active_msvc.bat\" \"${file}\""
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "C++: Run active file",
            "type": "shell",
            "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "dependsOn": "C++: Build active file (MSVC C++20)",
            "problemMatcher": []
        }
    ]
}